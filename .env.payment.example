# SAMA AI billing and update configuration

# Public website and download pages.
APP_WEBSITE_URL=https://samaail.netlify.app/
APP_DOWNLOAD_URL=https://69fc831415505220d12439eb--profound-sfogliatella-81eec2.netlify.app/#download

# Version policy.
# The desktop app sends its installed version to the server.
# If installed version < APP_MIN_SUPPORTED_VERSION, the app blocks and opens APP_DOWNLOAD_URL.
APP_LATEST_VERSION=2.0.0
APP_MIN_SUPPORTED_VERSION=2.0.0
APP_FORCE_UPDATE=false

# LemonSqueezy checkout and webhook.
LEMONSQUEEZY_CHECKOUT_URL=https://samaai.lemonsqueezy.com/checkout/buy/4e1e15f2-b41c-4631-8457-af7aadb738d0
LEMONSQUEEZY_WEBHOOK_SECRET=replace_with_lemonsqueezy_webhook_signing_secret

# Payment mapping in code:
# USD 2  -> 1 day
# USD 10 -> 7 days
# USD 30 -> 30 days

# Optional legacy Stripe support. Leave blank if you use only LemonSqueezy.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DAY_PRICE_ID=
STRIPE_WEEK_PRICE_ID=
STRIPE_MONTH_PRICE_ID=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# Public server URL where the FastAPI server is deployed.
# Example: https://sama-ai-license-server.onrender.com
PUBLIC_BASE_URL=https://your-server-url

# Manual admin renewal protection for POST /renew/{email}
ADMIN_RENEW_TOKEN=replace_with_a_long_random_secret
